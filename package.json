{
  "name": "pure-liquid-local-ai-client",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "api": "nx serve api",
    "ui": "nx serve ui",
    "landing": "cross-env NG_ALLOWED_HOSTS=localhost,127.0.0.1 nx serve landing",
    "build:api": "nx build api",
    "build:ui": "nx build ui",
    "build:landing": "nx build landing",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "gen:client": "npx @openapitools/openapi-generator-cli generate -i ./openapi.json -g typescript-angular -o ./apps/ui/src/app/client --additional-properties=ngVersion=21,providedIn=root,useStandalone=true",
    "gen:invoke": "npx @openapitools/openapi-generator-cli generate -i http://127.0.0.1:9090/openapi.json -g typescript-nestjs -o ./apps/api/src/modules/invoke --global-property models",
    "start": "cross-env NG_ALLOWED_HOSTS=localhost,127.0.0.1 nx run-many --target=serve --projects=api,ui,landing"
  },
